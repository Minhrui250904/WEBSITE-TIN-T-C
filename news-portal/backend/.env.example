PORT=5000
JWT_SECRET=change_me_to_a_long_random_secret

# VIP approval email target (owner/admin inbox)
VIP_APPROVAL_EMAIL=phanthechung9a3nct@gmail.com

# Public URL of backend for approval links in email
PUBLIC_API_URL=http://localhost:5000

# Optional separate secret for VIP approve/reject links
VIP_APPROVAL_TOKEN_SECRET=change_me_to_another_long_secret

# SMTP config (example for Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM=News Portal <your_gmail@gmail.com>

# AI provider config (OpenAI | Azure OpenAI | Gemini)
# AI_PROVIDER=auto|openai|azure|gemini
AI_PROVIDER=auto
AI_REQUEST_TIMEOUT_MS=30000

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI
